{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Samachar Output Contract v1.0",
    "description": "Deterministic, ingestion-ready news signal output from Samachar for Samruddhi consumption",
    "version": "1.0.0",
    "type": "object",
    "required": [
        "id",
        "timestamp",
        "source",
        "title",
        "content",
        "summary",
        "sentiment",
        "market_relevance",
        "ingestion_ready"
    ],
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique identifier for the news item (UUID or hash-based)",
            "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$",
            "examples": [
                "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
            ]
        },
        "timestamp": {
            "type": "string",
            "description": "ISO 8601 timestamp of ingestion (UTC)",
            "format": "date-time",
            "examples": [
                "2026-04-24T10:30:00Z"
            ]
        },
        "source": {
            "type": "string",
            "description": "Original source of the news (RSS feed URL, scraper name, API endpoint)",
            "minLength": 1,
            "maxLength": 500,
            "examples": [
                "https://news.google.com/rss?topic=business",
                "yahoo_finance_rss",
                "economictimes_scraper"
            ]
        },
        "title": {
            "type": "string",
            "description": "Cleaned, deduplicated news title",
            "minLength": 1,
            "maxLength": 300,
            "examples": [
                "Reliance Industries Reports Q3 Profit Surge of 15%"
            ]
        },
        "content": {
            "type": "string",
            "description": "Full article content (cleaned HTML, normalized whitespace)",
            "minLength": 10,
            "maxLength": 50000,
            "examples": [
                "Reliance Industries Ltd reported a 15% increase in quarterly profit..."
            ]
        },
        "summary": {
            "type": "object",
            "description": "AI-generated or heuristic summary of the article",
            "required": [
                "text",
                "confidence"
            ],
            "properties": {
                "text": {
                    "type": "string",
                    "description": "Concise summary (2-5 sentences)",
                    "minLength": 10,
                    "maxLength": 1000,
                    "examples": [
                        "Reliance Industries posted strong Q3 results driven by retail and digital growth."
                    ]
                },
                "confidence": {
                    "type": "number",
                    "description": "Confidence score of the summary quality (0.0 to 1.0)",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "examples": [
                        0.87
                    ]
                }
            },
            "additionalProperties": false
        },
        "sentiment": {
            "type": "object",
            "description": "Financial sentiment analysis result",
            "required": [
                "label",
                "score"
            ],
            "properties": {
                "label": {
                    "type": "string",
                    "description": "Sentiment classification",
                    "enum": [
                        "positive",
                        "negative",
                        "neutral"
                    ],
                    "examples": [
                        "positive"
                    ]
                },
                "score": {
                    "type": "number",
                    "description": "Sentiment score (-1.0 for most negative, +1.0 for most positive)",
                    "minimum": -1.0,
                    "maximum": 1.0,
                    "examples": [
                        0.72
                    ]
                }
            },
            "additionalProperties": false
        },
        "entities": {
            "type": "array",
            "description": "Extracted named entities (companies, persons, locations, etc.)",
            "items": {
                "type": "string"
            },
            "minItems": 0,
            "maxItems": 50,
            "default": [],
            "examples": [
                [
                    "Reliance Industries",
                    "Mukesh Ambani",
                    "Mumbai"
                ],
                []
            ]
        },
        "tags": {
            "type": "array",
            "description": "Categorization tags (sector, topic, market segment)",
            "items": {
                "type": "string"
            },
            "minItems": 0,
            "maxItems": 20,
            "default": [],
            "examples": [
                [
                    "earnings",
                    "oil_and_gas",
                    "large_cap"
                ],
                [
                    "policy",
                    "banking",
                    "rbi"
                ]
            ]
        },
        "market_relevance": {
            "type": "object",
            "description": "Market impact assessment for trading decisions",
            "required": [
                "impact_score"
            ],
            "properties": {
                "sector": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Relevant market sector (if applicable)",
                    "enum": [
                        "technology",
                        "banking",
                        "pharma",
                        "energy",
                        "auto",
                        "FMCG",
                        "metals",
                        "real_estate",
                        "telecom",
                        "infrastructure",
                        "consumer_goods",
                        "healthcare",
                        "finance",
                        "agriculture",
                        "general",
                        null
                    ],
                    "default": null,
                    "examples": [
                        "energy",
                        "banking"
                    ]
                },
                "impact_score": {
                    "type": "number",
                    "description": "Estimated market impact score (0.0 = no impact, 1.0 = high impact)",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "examples": [
                        0.85
                    ]
                }
            },
            "additionalProperties": false
        },
        "ingestion_ready": {
            "type": "boolean",
            "description": "Flag indicating if this item passed all validation checks and is ready for Samruddhi",
            "const": true
        }
    },
    "additionalProperties": false,
    "examples": [
        {
            "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
            "timestamp": "2026-04-24T10:30:00Z",
            "source": "https://news.google.com/rss?topic=business",
            "title": "Reliance Industries Reports Q3 Profit Surge of 15%",
            "content": "Reliance Industries Ltd reported a 15% increase in quarterly profit driven by strong performance in retail and digital services segments...",
            "summary": {
                "text": "Reliance Industries posted strong Q3 results with 15% profit growth, driven by retail expansion and Jio subscriber growth.",
                "confidence": 0.87
            },
            "sentiment": {
                "label": "positive",
                "score": 0.72
            },
            "entities": [
                "Reliance Industries",
                "Mukesh Ambani",
                "Mumbai"
            ],
            "tags": [
                "earnings",
                "oil_and_gas",
                "large_cap",
                "telecom"
            ],
            "market_relevance": {
                "sector": "energy",
                "impact_score": 0.85
            },
            "ingestion_ready": true
        }
    ]
}